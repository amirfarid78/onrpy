{
  "name": "temp_app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "set NODE_OPTIONS=--max-old-space-size=4096 && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "seed:production": "node scripts/seed-production.js",
    "install:vps": "bash scripts/install-vps.sh",
    "install:digitalocean": "bash scripts/install-digitalocean.sh",
    "db:migrate": "npx prisma migrate deploy --schema=prisma/schema.prisma",
    "db:seed": "node scripts/seed-production.js",
    "db:generate": "npx prisma generate --schema=prisma/schema.prisma",
    "db:reset": "npx prisma migrate reset --force --schema=prisma/schema.prisma && node scripts/seed-production.js"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^5.22.0",
    "bcrypt": "^6.0.0",
    "clsx": "^2.1.1",
    "firebase": "^12.7.0",
    "firebase-admin": "^13.6.0",
    "framer-motion": "^12.26.2",
    "jose": "^6.1.3",
    "lucide-react": "^0.562.0",
    "next": "16.1.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.1",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.23",
    "babel-plugin-react-compiler": "1.0.0",
    "dotenv": "^17.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "postcss": "^8.5.6",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}